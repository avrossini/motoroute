############################################################
# MotoRoute — template de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# .env é lido automaticamente pelo Docker Compose.
# NÃO commitar .env nem .env.production com valores reais.
############################################################

# ── Postgres (banco local Docker) ─────────────────────────
POSTGRES_PASSWORD=postgres

# ── Supabase JWT (ambiente local) ─────────────────────────
# Os valores abaixo são os padrões de desenvolvimento do Supabase.
# São públicos e seguros para uso local — NÃO usar em produção.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqd70ul-aqQVVwamFjdYoxB84L1TsWbH8
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0

# ── APIs externas ─────────────────────────────────────────
# Google Cloud: habilitar Directions API + Places API (New) + Geocoding API
# console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=AIzaSy...

# WeatherAPI: https://www.weatherapi.com/my/ → API Key
# Confirmar plano: precisa de previsão de 7 dias
WEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Expo Go no celular (opcional) ─────────────────────────
# Defina o IP da sua máquina para usar Expo Go em dispositivo físico.
# Descobrir IP: ipconfig (Windows)
HOST_IP=localhost
